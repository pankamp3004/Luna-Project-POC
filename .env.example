# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-api03-O2L4cm5h-dYWpZnrXsz9NoYSsCtt7FgRVo061upcfXQ8K8qYr9aPM488V9R9aWzV4PqL8Uvy8BOefAuIp3xbPw-9nAFxwA

# Gmail IMAP credentials (use App Password, not your real password)
# To get App Password: Google Account -> Security -> App Passwords
GMAIL_ADDRESS=mail
GMAIL_APP_PASSWORD=xxxx xxxx xxxx

# Who receives the replies (for POC testing, can be same as sender)
REPLY_FROM_NAME=Luna
REPLY_FROM_EMAIL=

# Business hours for sending emails
# Format: 24-hour format (0-23)
# Emails outside these hours will be held (status: HOLD) until next business day
SENDING_HOUR_START=10
SENDING_HOUR_END=19

# Timezone for business hours (default: Asia/Kolkata for India)
# Use IANA timezone names: Asia/Kolkata, America/New_York, Europe/London, etc.
TIMEZONE=Asia/Kolkata

